<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Product</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body class="flex-col">
    <div class="flex">
      <nav class="w-1/8"><%- include("./nav.ejs") %></nav>
      <div class="flex-1 flex-col bg-[url('/picture/adminHome.png')] bg-cover">
        <div>
          <p class="text-5xl font-bold text-white text-center pt-5">
            Quản Lý Sản Phẩm
          </p>
        </div>
        <div class="mt-[30px] ms-9">
          <button
            type="button"
            id="add"
            class="me-8 text-xl bg-blue-600 text-white font-semibold py-2 px-3 rounded-xl shadow-lg transition-all transform hover:scale-[1.02] mx-auto"
          >
            <i class="fa-solid fa-plus text-white"></i>
            Thêm
          </button>
        </div>
        <div>
          <table class="w-[95%] text-center mx-auto">
            <tr class="bg-gray-800 text-white">
              <th class="py-3">STT</th>
              <th class="py-3">Hình ảnh</th>
              <th class="py-3">Tên sản phẩm</th>
              <th class="py-3">Thương hiệu</th>
              <th class="py-3">Màu sắc</th>
              <th class="py-3">Đơn giá</th>
              <th class="py-3">Số lượng</th>
              <th class="py-3">Chức năng</th>
            </tr>
            <% products.forEach((product, index) => { %>
            <tr class="bg-white hover:bg-gray-50 transition">
              <td class="px-4 py-2"><%= ++index %></td>
              <td class="px-4 py-2"><%= product.pricture %></td>
              <td class="px-4 py-2"><%= product.name %></td>
              <td class="px-4 py-2"><%= product.Brand.name %></td>
              <td class="px-4 py-2"><%= product.color %></td>
              <td class="px-4 py-2"><%= product.unitPrice %></td>
              <td class="px-4 py-2"><%= product.quantity %></td>
              <td class="flex justify-around py-2">
                <button class="bg-yellow-500 px-7 py-1 rounded-full update">
                  <i class="fas fa-edit"></i> Sửa
                </button>
                <button class="bg-red-500 px-7 py-1 rounded-full delete">
                  <i class="fas fa-trash-can"></i> Xóa
                </button>
              </td>
            </tr>
            <% }) %>
          </table>
        </div>
        <div class="flex justify-center mt-6">
          <% for (let i = 1; i <= totalPages; i++) { %>
          <a
            href="?page=<%= i %>"
            class="mx-1 px-3 py-1 rounded-lg <%= currentPage === i ? 'bg-blue-600 text-white' : 'bg-gray-300 text-gray-700 hover:bg-blue-400 hover:text-white transition' %>"
          >
            <%= i %>
          </a>
          <% } %>
        </div>
      </div>
    </div>
    <footer><%- include("./footer.ejs") %></footer>
  </body>
  <script>
    document.getElementById('add').addEventListener('click', (e) => {
      location.href = '/admin/product/new';
    });
  </script>
</html>
